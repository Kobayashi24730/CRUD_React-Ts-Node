{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "#/*": ["src/*"]
    },

    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "skipLibCheck": true,
  }
}
